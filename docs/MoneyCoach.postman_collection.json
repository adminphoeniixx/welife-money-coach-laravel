{
  "info": {
    "name": "MoneyCoach API",
    "description": "Mobile REST API for the MoneyCoach iOS app (Laravel Sanctum token auth). Login or Register first — the token is saved to the {{token}} collection variable automatically. See docs/MoneyCoach-API.md.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000/api" },
    { "key": "token", "value": "" },
    { "key": "reset_token", "value": "" }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": ["pm.request.headers.upsert({ key: 'Accept', value: 'application/json' });"]
      }
    }
  ],
  "item": [
    {
      "name": "1. Auth & Onboarding",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('token', pm.response.json().token);",
                  "  pm.test('token saved', () => pm.expect(pm.collectionVariables.get('token')).to.be.a('string'));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "url": { "raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth", "register"] },
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "name", "value": "Rahul Sharma" },
                { "key": "email", "value": "rahul@example.com" },
                { "key": "password", "value": "Password!234" },
                { "key": "password_confirmation", "value": "Password!234" },
                { "key": "device_name", "value": "Postman" }
              ]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  pm.collectionVariables.set('token', pm.response.json().token);",
                  "  pm.test('token saved', () => pm.expect(pm.collectionVariables.get('token')).to.be.a('string'));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "email", "value": "test@example.com" },
                { "key": "password", "value": "password" },
                { "key": "device_name", "value": "Postman" }
              ]
            }
          }
        },
        {
          "name": "Forgot password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "url": { "raw": "{{base_url}}/auth/forgot-password", "host": ["{{base_url}}"], "path": ["auth", "forgot-password"] },
            "body": { "mode": "urlencoded", "urlencoded": [{ "key": "email", "value": "test@example.com" }] }
          }
        },
        {
          "name": "Reset password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "url": { "raw": "{{base_url}}/auth/reset-password", "host": ["{{base_url}}"], "path": ["auth", "reset-password"] },
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "token", "value": "{{reset_token}}" },
                { "key": "email", "value": "test@example.com" },
                { "key": "password", "value": "NewPass!234" },
                { "key": "password_confirmation", "value": "NewPass!234" }
              ]
            }
          }
        },
        {
          "name": "Me (current user)",
          "request": { "method": "GET", "url": { "raw": "{{base_url}}/user", "host": ["{{base_url}}"], "path": ["user"] } }
        },
        {
          "name": "Logout (this device)",
          "request": { "method": "POST", "url": { "raw": "{{base_url}}/auth/logout", "host": ["{{base_url}}"], "path": ["auth", "logout"] } }
        },
        {
          "name": "Logout all devices",
          "request": { "method": "POST", "url": { "raw": "{{base_url}}/auth/logout-all", "host": ["{{base_url}}"], "path": ["auth", "logout-all"] } }
        },
        {
          "name": "Onboarding — options",
          "request": { "method": "GET", "url": { "raw": "{{base_url}}/onboarding", "host": ["{{base_url}}"], "path": ["onboarding"] } }
        },
        {
          "name": "Onboarding — save",
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/onboarding", "host": ["{{base_url}}"], "path": ["onboarding"] },
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "currency", "value": "INR" },
                { "key": "primary_goal", "value": "get_out_of_debt" },
                { "key": "notifications_enabled", "value": "1" },
                { "key": "locale", "value": "en-IN" },
                { "key": "country", "value": "IN" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "2. Dashboard & Coach",
      "item": [
        { "name": "Dashboard (home)", "request": { "method": "GET", "url": { "raw": "{{base_url}}/dashboard", "host": ["{{base_url}}"], "path": ["dashboard"] } } },
        { "name": "Debt payoff coach", "request": { "method": "GET", "url": { "raw": "{{base_url}}/coach?strategy=avalanche&extra=2000", "host": ["{{base_url}}"], "path": ["coach"], "query": [{ "key": "strategy", "value": "avalanche" }, { "key": "extra", "value": "2000" }] } } }
      ]
    },
    {
      "name": "3. Transactions",
      "item": [
        { "name": "List", "request": { "method": "GET", "url": { "raw": "{{base_url}}/transactions?type=all", "host": ["{{base_url}}"], "path": ["transactions"], "query": [{ "key": "type", "value": "all" }] } } },
        {
          "name": "Create entry",
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/entries", "host": ["{{base_url}}"], "path": ["entries"] },
            "body": { "mode": "urlencoded", "urlencoded": [
              { "key": "type", "value": "expense" },
              { "key": "amount", "value": "640.50" },
              { "key": "category", "value": "Food" },
              { "key": "description", "value": "Swiggy" },
              { "key": "payee", "value": "Swiggy" },
              { "key": "method", "value": "UPI" },
              { "key": "occurred_on", "value": "2026-07-10" }
            ] }
          }
        },
        {
          "name": "Update entry",
          "request": {
            "method": "PUT",
            "url": { "raw": "{{base_url}}/entries/1", "host": ["{{base_url}}"], "path": ["entries", "1"] },
            "body": { "mode": "urlencoded", "urlencoded": [
              { "key": "type", "value": "expense" },
              { "key": "amount", "value": "700" },
              { "key": "occurred_on", "value": "2026-07-10" }
            ] }
          }
        },
        { "name": "Delete entry", "request": { "method": "DELETE", "url": { "raw": "{{base_url}}/entries/1", "host": ["{{base_url}}"], "path": ["entries", "1"] } } }
      ]
    },
    {
      "name": "4. Debts",
      "item": [
        { "name": "List", "request": { "method": "GET", "url": { "raw": "{{base_url}}/debts", "host": ["{{base_url}}"], "path": ["debts"] } } },
        { "name": "Detail + payment history", "request": { "method": "GET", "url": { "raw": "{{base_url}}/debts/1", "host": ["{{base_url}}"], "path": ["debts", "1"] } } },
        {
          "name": "Create loan",
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/debts", "host": ["{{base_url}}"], "path": ["debts"] },
            "body": { "mode": "urlencoded", "urlencoded": [
              { "key": "name", "value": "HDFC Home Loan" },
              { "key": "institution", "value": "HDFC" },
              { "key": "kind", "value": "loan" },
              { "key": "category", "value": "home" },
              { "key": "interest_rate", "value": "8.5" },
              { "key": "balance", "value": "2500000" },
              { "key": "principal", "value": "3000000" },
              { "key": "emi", "value": "24500" },
              { "key": "total_emis", "value": "240" },
              { "key": "emis_paid", "value": "60" },
              { "key": "due_day", "value": "5" }
            ] }
          }
        },
        {
          "name": "Create credit card",
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/debts", "host": ["{{base_url}}"], "path": ["debts"] },
            "body": { "mode": "urlencoded", "urlencoded": [
              { "key": "name", "value": "HDFC Regalia" },
              { "key": "kind", "value": "credit_card" },
              { "key": "interest_rate", "value": "42" },
              { "key": "balance", "value": "45000" },
              { "key": "credit_limit", "value": "200000" },
              { "key": "min_due", "value": "2500" },
              { "key": "due_day", "value": "18" }
            ] }
          }
        },
        {
          "name": "Update debt",
          "request": {
            "method": "PUT",
            "url": { "raw": "{{base_url}}/debts/1", "host": ["{{base_url}}"], "path": ["debts", "1"] },
            "body": { "mode": "urlencoded", "urlencoded": [
              { "key": "name", "value": "HDFC Home Loan" },
              { "key": "kind", "value": "loan" },
              { "key": "interest_rate", "value": "8.4" },
              { "key": "balance", "value": "2400000" }
            ] }
          }
        },
        { "name": "Delete debt", "request": { "method": "DELETE", "url": { "raw": "{{base_url}}/debts/1", "host": ["{{base_url}}"], "path": ["debts", "1"] } } },
        {
          "name": "Record payment (EMI)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/debts/1/payment", "host": ["{{base_url}}"], "path": ["debts", "1", "payment"] },
            "body": { "mode": "urlencoded", "urlencoded": [{ "key": "amount", "value": "24500" }] }
          }
        },
        {
          "name": "Attach documents (multipart)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/debts/1/documents", "host": ["{{base_url}}"], "path": ["debts", "1", "documents"] },
            "body": { "mode": "formdata", "formdata": [{ "key": "documents[]", "type": "file", "src": [] }] }
          }
        },
        { "name": "View attachment", "request": { "method": "GET", "url": { "raw": "{{base_url}}/debt-documents/1/view", "host": ["{{base_url}}"], "path": ["debt-documents", "1", "view"] } } },
        { "name": "Download attachment", "request": { "method": "GET", "url": { "raw": "{{base_url}}/debt-documents/1/download", "host": ["{{base_url}}"], "path": ["debt-documents", "1", "download"] } } },
        { "name": "Delete attachment", "request": { "method": "DELETE", "url": { "raw": "{{base_url}}/debt-documents/1", "host": ["{{base_url}}"], "path": ["debt-documents", "1"] } } }
      ]
    },
    {
      "name": "5. Net Worth / Assets",
      "item": [
        { "name": "Net worth", "request": { "method": "GET", "url": { "raw": "{{base_url}}/net-worth", "host": ["{{base_url}}"], "path": ["net-worth"] } } },
